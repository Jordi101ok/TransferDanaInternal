@model TransferDanaInternal.Models.TransferViewModel
@{
    ViewData["Title"] = "Index";
}
<h1>Transfer</h1>
<h4>TransferForm</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Index" method="post" id="transferForm">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label class="control-label">Source Account</label>
                <select name="sourceAccountNumber" class="form-control" id="sourceAccountNumber">
                    <option value="">-- Select Source Account --</option>
                    @foreach (var acc in Model.SourceAccounts)
                    {
                        <option value="@acc.AccountNumber" data-balance="@acc.Balance">
                            @acc.AccountNumber - @acc.AccountName (Rp @acc.Balance)
                        </option>
                    }
                </select>
                <span class="text-danger" id="sourceError"></span>
            </div>

            <div class="form-group">
                <label class="control-label">Destination Account</label>
                <select name="destinationAccountNumber" class="form-control" id="destinationAccountNumber">
                    <option value="">-- Select Destination Account --</option>
                    @foreach (var acc in Model.DestinationAccounts)
                    {
                        <option value="@acc.AccountNumber">
                            @acc.AccountNumber - @acc.AccountName
                        </option>
                    }
                </select>
                <span class="text-danger" id="destinationError"></span>
            </div>

            <div class="form-group">
                <label class="control-label">Amount</label>
                <input name="amount" class="form-control" id="amount" placeholder="Enter amount" />
                <span class="text-danger" id="amountError"></span>
            </div>

            <div class="form-group">
                <label class="control-label">Description</label>
                <input name="description" class="form-control" id="description" placeholder="Max 40 characters" maxlength="40" />
                <span id="charCount" class="text-muted" style="font-size:0.85em;">0 / 40</span>
                <span class="text-danger" id="descriptionError"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Transfer" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>
<div>
    <a asp-controller="Transfer" asp-action="Logout">Logout</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>

        const description = document.getElementById('description');
        const charCount = document.getElementById('charCount');
        description.addEventListener('input', function () {
            charCount.textContent = `${this.value.length} / 40`;
        });

        document.getElementById('transferForm').addEventListener('submit', function (e) {
            let isValid = true;

            document.getElementById('sourceError').textContent = '';
            document.getElementById('destinationError').textContent = '';
            document.getElementById('amountError').textContent = '';
            document.getElementById('descriptionError').textContent = '';

            const source = document.getElementById('sourceAccountNumber');
            const destination = document.getElementById('destinationAccountNumber');
            const amount = document.getElementById('amount');
            const desc = document.getElementById('description');

            // source account empty
            if (source.value === '') {
                document.getElementById('sourceError').textContent = 'Please select a source account.';
                isValid = false;
            }

            // destination account empty
            if (destination.value === '') {
                document.getElementById('destinationError').textContent = 'Please select a destination account.';
                isValid = false;
            }

            // amount empty
            if (amount.value.trim() === '') {
                document.getElementById('amountError').textContent = 'Amount is required.';
                isValid = false;
            }
            // amount not number
            else if (isNaN(amount.value) || amount.value.trim() === '') {
                document.getElementById('amountError').textContent = 'Amount must be a valid number.';
                isValid = false;
            }
            // amount <= 0
            else if (parseFloat(amount.value) <= 0) {
                document.getElementById('amountError').textContent = 'Amount must be greater than 0.';
                isValid = false;
            }
            // amount > balance
            else if (source.value !== '') {
                const selectedOption = source.options[source.selectedIndex];
                const balance = parseFloat(selectedOption.getAttribute('data-balance'));
                if (parseFloat(amount.value) > balance) {
                    document.getElementById('amountError').textContent = `Amount exceeds source account balance (Rp ${balance.toLocaleString()}).`;
                    isValid = false;
                }
            }

            // description empty
            if (desc.value.trim() === '') {
                document.getElementById('descriptionError').textContent = 'Description is required.';
                isValid = false;
            }
            // description > 40 characters
            else if (desc.value.length > 40) {
                document.getElementById('descriptionError').textContent = 'Description must not exceed 40 characters.';
                isValid = false;
            }

            if (!isValid) {
                e.preventDefault();
            }
        });
    </script>
}