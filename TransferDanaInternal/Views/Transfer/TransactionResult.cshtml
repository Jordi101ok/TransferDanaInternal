@model TransferDanaInternal.Models.TransferForm

<h2>Transfer Successful</h2>

<div class="card p-3">
    <p><strong>From:</strong> @Model.SourceAccount.AccountNumber - @Model.SourceAccount.AccountName</p>
    <p><strong>To:</strong> @Model.DestinationAccount.AccountNumber - @Model.DestinationAccount.AccountName</p>
    <p><strong>Amount:</strong> @Model.Amount.ToString("C")</p>
    <p><strong>Description:</strong> @Model.Description</p>
    <p><strong>Current Balance for @Model.SourceAccount.AccountNumber - @Model.SourceAccount.AccountName: </strong> @Model.SourceAccount.Balance</p>
</div>

<br />

<a asp-action="Index" class="btn btn-primary">Back to Transfer</a>